{
  "name": "impact-guard-vscode",
  "displayName": "Impact Guard",
  "description": "Enterprise Line-Level Impact Analyzer for Angular Applications",
  "version": "2.0.0",
  "publisher": "antigravity",
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:impact-guard-view",
    "onLanguage:typescript",
    "onLanguage:html",
    "onLanguage:scss",
    "onLanguage:css",
    "onLanguage:less",
    "workspaceContains:**/angular.json"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "configuration": {
      "title": "Impact Guard",
      "properties": {
        "impactGuard.exclude": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [],
          "description": "Additional folders to exclude from indexing (relative to workspace root, e.g. ['src/assets', 'dist-dev'])"
        },
        "impactGuard.indexingMode": {
          "type": "string",
          "enum": [
            "prompt",
            "style-focused",
            "full"
          ],
          "default": "prompt",
          "enumDescriptions": [
            "Ask the user to choose the indexing mode on activation",
            "Index only open style files and their @import chains (fast, recommended for enterprise)",
            "Index all supported files in the workspace (comprehensive, slower)"
          ],
          "description": "Controls how Impact Guard discovers and indexes files. 'prompt' asks on activation, 'style-focused' indexes from open .less/.css/.scss files and their imports, 'full' indexes everything."
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "impact-guard-container",
          "title": "Impact Guard",
          "icon": "$(shield)"
        }
      ]
    },
    "views": {
      "impact-guard-container": [
        {
          "id": "impact-guard-view",
          "name": "Impact Analyzer",
          "type": "tree"
        }
      ]
    },
    "commands": [
      {
        "command": "impact-guard.analyzeSymbol",
        "title": "Impact Guard: Analyze Current Symbol",
        "icon": "$(search)"
      },
      {
        "command": "impact-guard.analyzeFile",
        "title": "Impact Guard: Analyze Current File",
        "icon": "$(file-code)"
      },
      {
        "command": "impact-guard.analyzeWorkspace",
        "title": "Impact Guard: Analyze Workspace"
      },
      {
        "command": "impact-guard.rebuildIndex",
        "title": "Impact Guard: Rebuild Index",
        "icon": "$(refresh)"
      },
      {
        "command": "impact-guard.showDependencyGraph",
        "title": "Impact Guard: Show Dependency Graph"
      },
      {
        "command": "impact-guard.exportReport",
        "title": "Impact Guard: Export Report",
        "icon": "$(export)"
      },
      {
        "command": "impact-guard.openAndHighlight",
        "title": "Impact Guard: Open File & Highlight"
      },
      {
        "command": "impact-guard.showIndexingLog",
        "title": "Impact Guard: Show Indexing Log"
      },
      {
        "command": "impact-guard.switchIndexingMode",
        "title": "Impact Guard: Switch Indexing Mode",
        "icon": "$(settings-gear)"
      }
    ]
  },
  "scripts": {
    "vscode:prepublish": "npm run build",
    "build": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs",
    "watch": "esbuild src/extension.ts --bundle --outfile=dist/extension.js --external:vscode --platform=node --format=cjs --watch",
    "clean": "tsc -b --clean"
  },
  "dependencies": {
    "@impact-guard/engine": "*"
  },
  "devDependencies": {
    "@types/vscode": "^1.80.0"
  }
}
