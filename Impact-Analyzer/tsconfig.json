{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ES2022"],
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "composite": true,
    "declaration": true,
    "sourceMap": true
  },
  "files": [],
  "references": [
    { "path": "packages/engine" },
    { "path": "packages/cli" },
    { "path": "packages/extension" },
    { "path": "packages/sample-app" }
  ]
}
